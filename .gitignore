# Ignore all markdown and planning files except README.md
*.md
!README.md
implementation_plan2

# Ignore all actual code files in backend and frontend to preserve skeleton structure
/backend/*
!/backend/.gitkeep

# Ignore all actual code files in frontend to preserve skeleton structure, except base config and src folders
/frontend/*
!/frontend/package.json
!/frontend/index.html
!/frontend/vite.config.js
!/frontend/src/
/frontend/src/*
!/frontend/src/main.jsx
!/frontend/src/App.jsx
!/frontend/src/index.css
!/frontend/src/components/
!/frontend/src/pages/
!/frontend/src/services/
!/frontend/src/assets/
!/frontend/**/.gitkeep
!/frontend/.gitkeep

# Standard node ignores just in case
node_modules/
.env
