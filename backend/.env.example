# ========================================
# HIRE ME - BACKEND ENVIRONMENT VARIABLES
# ========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (SQLite for dev, replace with MySQL/Postgres URI for prod)
DB_DIALECT=sqlite
DB_STORAGE=./hire_me_db.sqlite
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=secret
# DB_NAME=hire_me_prod

# Authentication (JSON Web Token)
# Generate a strong secret key (e.g., using `require('crypto').randomBytes(64).toString('hex')`)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Socket.io Configuration
CORS_ORIGIN=http://localhost:5173

# Third-Party API Keys (Future Recommendations)
# STRIPE_SECRET_KEY=sk_test_...
# GOOGLE_MAPS_API_KEY=AIza...
